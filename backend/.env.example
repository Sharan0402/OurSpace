# =========================================================================
# Our Space — BACKEND environment (Java Spring Boot)
# Source these before `mvn spring-boot:run`, or set them in your deploy target.
# NEVER commit real secrets. Prefer AWS Secrets Manager / SSM in production.
# =========================================================================

# ---- Persistence ----
# "memory" runs with zero AWS (dev). "dynamo" uses Amazon DynamoDB.
APP_PERSISTENCE=memory

# ---- CORS / frontend ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- Amazon Cognito (JWT validation) ----
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
# Comma-separated Cognito `sub`s of the ONLY two authorized users.
# Leave blank in dev to disable the allow-list check.
AUTHORIZED_USER_IDS=

# ---- Encryption (Spotify refresh token at rest) ----
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ---- Spotify (SECRET stays here, never in the frontend) ----
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Spotify requires a loopback IP (127.0.0.1), NOT "localhost", for http redirects.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/api/spotify/callback

# ---- DynamoDB (only used when APP_PERSISTENCE=dynamo) ----
# For DynamoDB Local: DYNAMO_ENDPOINT=http://localhost:8000
DYNAMO_ENDPOINT=
TABLE_MESSAGES=our-space-messages
TABLE_CONVERSATIONS=our-space-conversations
TABLE_SPOTIFY_TOKENS=our-space-spotify-tokens
TABLE_SYNC_SESSIONS=our-space-sync-sessions
