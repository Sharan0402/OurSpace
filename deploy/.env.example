# Copy to deploy/.env and fill in. NEVER commit deploy/.env (it holds secrets).

# ---- Domain (the https host you registered + pointed at this box) ----
DOMAIN=ourspace.example.com

# ---- Built-in two-person auth ----
# Signing key for session tokens. Generate: openssl rand -base64 48
APP_JWT_SECRET=
# What each of you types to log in, plus a password each.
APPY_USERNAME=appy
APPY_PASSWORD=
LAKKU_USERNAME=lakku
LAKKU_PASSWORD=

# ---- Encryption for stored Spotify refresh tokens ----
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ---- Spotify app (from developer.spotify.com/dashboard) ----
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ---- AWS (IAM user with the deploy/iam-policy.json permissions) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
