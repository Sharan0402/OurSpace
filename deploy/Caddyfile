# Auto-HTTPS (Let's Encrypt) for {$DOMAIN}. Routes the API + WebSocket to the
# backend and everything else to the Next.js frontend. Caddy upgrades the
# WebSocket automatically inside reverse_proxy.

# Redirect www → apex (Caddy fetches a cert for www too, so this needs a
# www DNS record pointing at this box as well).
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

{$DOMAIN} {
	encode gzip

	@api path /api/*
	handle @api {
		reverse_proxy backend:8080
	}

	@ws path /ws*
	handle @ws {
		reverse_proxy backend:8080
	}

	handle {
		reverse_proxy frontend:3000
	}
}
