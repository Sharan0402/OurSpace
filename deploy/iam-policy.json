{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "OurSpaceDynamoAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:*:*:table/our-space-messages",
        "arn:aws:dynamodb:*:*:table/our-space-sync-sessions",
        "arn:aws:dynamodb:*:*:table/our-space-spotify-tokens"
      ]
    }
  ]
}
