# =========================================================================
# Our Space — FRONTEND environment (Next.js)
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# Only NEXT_PUBLIC_* vars are exposed to the browser — keep secrets OUT of them.
# =========================================================================

# ---- Backend (Java Spring Boot) ----
# Base URL of the Java backend REST API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# WebSocket (STOMP) endpoint of the Java backend for realtime chat + music sync.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# ---- Dev mode ----
# When "true", the frontend uses an in-browser mock realtime bus + mock data,
# so you can run the UI with no backend/AWS/Spotify configured.
NEXT_PUBLIC_USE_MOCKS=true

# When "true", Spotify uses REAL OAuth/SDK/Web API via the Java backend even if
# USE_MOCKS is true. Lets you test Spotify without setting up Cognito.
NEXT_PUBLIC_SPOTIFY_LIVE=false

# When "true", realtime (chat + sync) uses the backend STOMP WebSocket instead
# of the in-browser BroadcastChannel. Required to test across two DIFFERENT
# browsers. (Auto-on when NEXT_PUBLIC_USE_MOCKS=false.)
NEXT_PUBLIC_REALTIME_LIVE=false

# ---- Amazon Cognito (public client config; NOT a secret) ----
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Hosted UI domain (optional, if you use Cognito Hosted UI)
NEXT_PUBLIC_COGNITO_DOMAIN=https://our-space.auth.us-east-1.amazoncognito.com

# ---- Spotify (public client id only; secret lives in the Java backend) ----
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
# Where Spotify redirects after OAuth. Must match the backend + Spotify dashboard.
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/api/spotify/callback
# Where the backend sends the user back into the app after linking Spotify.
NEXT_PUBLIC_APP_URL=http://localhost:3000
